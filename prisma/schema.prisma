generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                     String                 @id @default(cuid())
  name                   String
  businessUnit           String
  defaultLanguage        String                 @default("zh-CN")
  defaultRegion          String                 @default("CN")
  industry               String?
  status                 String                 @default("active")
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  brandProfile           BrandProfile?
  llmConfig              LlmConfig?
  queryClusters          QueryCluster[]
  engineConfigs          EngineConfig[]
  samplingPlans          SamplingPlan[]
  samplingBatches        SamplingBatch[]
  answerRuns             AnswerRun[]
  answerEvidenceHits     AnswerEvidenceHit[]
  contentAssets          ContentAsset[]
  findings               Finding[]
  tasks                  Task[]
  experiments            Experiment[]
  strategyCards          StrategyCard[]
  authoritySources       AuthoritySource[]
  authorityOpportunities AuthorityOpportunity[]
  alertRules             AlertRule[]
  alerts                 Alert[]
  reports                Report[]
  integrations           IntegrationConfig[]
  auditLogs              AuditLog[]
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  role      String     @default("admin")
  createdAt DateTime   @default(now())
  tasks     Task[]
  auditLogs AuditLog[]
}

model BrandProfile {
  id              String       @id @default(cuid())
  projectId       String       @unique
  brandNames      String
  productNames    String
  aliases         String?
  customerGroups  String?
  description     String?
  brandUrls       String?
  forbiddenClaims String?
  approvedClaims  String?
  competitors     Competitor[]
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Competitor {
  id             String                 @id @default(cuid())
  brandProfileId String
  name           String
  aliases        String?
  customerGroups String?
  description    String?
  website        String?
  brandProfile   BrandProfile           @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  occurrences    CompetitorOccurrence[]
}

model QueryCluster {
  id                 String          @id @default(cuid())
  projectId          String
  name               String
  intentType         String
  funnelStage        String          @default("consideration")
  priority           Int             @default(3)
  businessValueScore Int             @default(50)
  targetMetric       String          @default("VAIR")
  ownerTeam          String          @default("Product")
  defaultEngineIds   String?
  status             String          @default("active")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queries            Query[]
  samplingBatches    SamplingBatch[]
  metrics            ClusterMetric[]
  findings           Finding[]
  tasks              Task[]
  experiments        Experiment[]
}

model Query {
  id                    String        @id @default(cuid())
  clusterId             String
  queryText             String
  language              String        @default("zh-CN")
  region                String        @default("CN")
  persona               String?
  device                String        @default("desktop")
  intentType            String
  expectedEvidenceTypes String?
  status                String        @default("active")
  version               Int           @default(1)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  cluster               QueryCluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  answerRuns            AnswerRun[]
  metrics               QueryMetric[]
}

model EngineConfig {
  id              String               @id @default(cuid())
  projectId       String
  engineType      String
  displayName     String
  connectorType   String               @default("browser")
  baseUrl         String
  region          String               @default("CN")
  language        String               @default("zh-CN")
  status          String               @default("active")
  rateLimitPolicy String?
  providerConfig  Json?
  createdAt       DateTime             @default(now())
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  answerRuns      AnswerRun[]
  samplingPlans   SamplingPlanEngine[]
}

model SamplingPlan {
  id          String               @id @default(cuid())
  projectId   String
  name        String
  frequency   String               @default("manual")
  repeatCount Int                  @default(1)
  status      String               @default("active")
  queryScope  String               @default("all_active")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  engines     SamplingPlanEngine[]
  jobs        SamplingJob[]
}

model SamplingPlanEngine {
  id             String       @id @default(cuid())
  samplingPlanId String
  engineConfigId String
  samplingPlan   SamplingPlan @relation(fields: [samplingPlanId], references: [id], onDelete: Cascade)
  engineConfig   EngineConfig @relation(fields: [engineConfigId], references: [id], onDelete: Cascade)
}

model SamplingJob {
  id             String          @id @default(cuid())
  planId         String
  scheduledAt    DateTime        @default(now())
  startedAt      DateTime?
  finishedAt     DateTime?
  status         String          @default("queued")
  queryCount     Int             @default(0)
  engineCount    Int             @default(0)
  failureSummary String?
  plan           SamplingPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  batches        SamplingBatch[]
  answerRuns     AnswerRun[]
}

model SamplingBatch {
  id            String       @id
  name          String?
  projectId     String
  clusterId     String
  samplingJobId String?
  batchDate     String
  sequence      Int
  createdAt     DateTime     @default(now())
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cluster       QueryCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  samplingJob   SamplingJob? @relation(fields: [samplingJobId], references: [id], onDelete: SetNull)
  answerRuns    AnswerRun[]

  @@unique([clusterId, batchDate, sequence])
  @@index([projectId, batchDate])
  @@index([clusterId, batchDate])
}

model AnswerRun {
  id                            String                 @id @default(cuid())
  projectId                     String
  queryId                       String
  engineConfigId                String
  samplingJobId                 String?
  samplingBatchId               String?
  runAt                         DateTime               @default(now())
  repeatIndex                   Int                    @default(0)
  status                        String                 @default("succeeded")
  answerText                    String
  rawResponseUri                String?
  screenshotUri                 String?
  failureReason                 String?
  engineMetadata                String?
  answerAnalysis                String?
  answerAnalysisAt              DateTime?
  answerAnalysisError           String?
  referenceFeatureAnalysis      String?
  referenceFeatureAnalysisAt    DateTime?
  referenceFeatureAnalysisError String?
  competitorReferenceFeatureAnalysis      String?
  competitorReferenceFeatureAnalysisAt    DateTime?
  competitorReferenceFeatureAnalysisError String?
  answerReferenceAnalysis       String?
  answerReferenceAnalysisAt     DateTime?
  answerReferenceAnalysisError  String?
  parseVersion                  String                 @default("v1")
  project                       Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  query                         Query                  @relation(fields: [queryId], references: [id], onDelete: Cascade)
  engineConfig                  EngineConfig           @relation(fields: [engineConfigId], references: [id], onDelete: Cascade)
  samplingJob                   SamplingJob?           @relation(fields: [samplingJobId], references: [id], onDelete: SetNull)
  samplingBatch                 SamplingBatch?         @relation(fields: [samplingBatchId], references: [id], onDelete: SetNull)
  sources                       Source[]
  citations                     Citation[]
  mentions                      Mention[]
  competitorOccurrences         CompetitorOccurrence[]
  metrics                       RunMetric?
  findingEvidence               FindingEvidence[]
  answerEvidenceHits            AnswerEvidenceHit[]
}

model AnswerEvidenceHit {
  id                      String    @id @default(cuid())
  projectId               String
  runId                   String
  analysisLabel           String
  analysisText            String
  analysisTextHash        String
  matched                 Boolean   @default(false)
  evidenceSubmoduleId     String?
  evidenceParentModuleId  String?
  evidenceText            String?
  evidenceTitle           String?
  evidenceLocationPath    String?
  reason                  String?
  modelName               String?
  analyzedAt              DateTime  @default(now())
  project                 Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run                     AnswerRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, analysisLabel, analysisTextHash])
  @@index([projectId, evidenceSubmoduleId])
}

model Source {
  id                   String     @id @default(cuid())
  runId                String
  url                  String
  domain               String
  title                String
  sourceType           String
  position             Int        @default(0)
  summary              String?
  keyword              String?
  siteName             String?
  fetchedUrl           String?
  bodyText             String?
  author               String?
  publishedAt          String?
  content              String?
  fetchMode            String?
  fetchError           String?
  fetchedAt            DateTime?
  referenceNature      String?
  referenceNatureAt    DateTime?
  referenceNatureError String?
  referenceFeatureAnalysis      String?
  referenceFeatureAnalysisAt    DateTime?
  referenceFeatureAnalysisError String?
  competitorReferenceFeatureAnalysis      String?
  competitorReferenceFeatureAnalysisAt    DateTime?
  competitorReferenceFeatureAnalysisError String?
  authorityScore       Int        @default(50)
  confidence           Float      @default(0.8)
  run                  AnswerRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  citations            Citation[]
}

model Citation {
  id             String    @id @default(cuid())
  runId          String
  sourceId       String?
  claimText      String
  claimLocation  String
  citationMarker String?
  supportStatus  String    @default("unverified")
  confidence     Float     @default(0.7)
  run            AnswerRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  source         Source?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)
}

model Mention {
  id            String    @id @default(cuid())
  runId         String
  entityType    String
  entityName    String
  canonicalName String
  location      String
  sentiment     String    @default("neutral")
  positionType  String    @default("body")
  run           AnswerRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model CompetitorOccurrence {
  id                   String      @id @default(cuid())
  runId                String
  competitorId         String?
  competitorName       String
  rankPosition         Int?
  recommendationReason String?
  run                  AnswerRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  competitor           Competitor? @relation(fields: [competitorId], references: [id], onDelete: SetNull)
}

model ContentAsset {
  id           String                @id @default(cuid())
  projectId    String
  url          String
  title        String
  assetType    String
  ownerTeam    String                @default("Content")
  status       String                @default("active")
  canonicalUrl String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  project      Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshots    ContentSnapshot[]
  mappings     AssetClusterMapping[]
  tasks        Task[]
}

model ContentSnapshot {
  id              String            @id @default(cuid())
  assetId         String
  snapshotAt      DateTime          @default(now())
  htmlUri         String?
  textContent     String
  httpStatus      Int               @default(200)
  contentHash     String
  crawlStatus     String            @default("crawled")
  asset           ContentAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  structure       StructureFeature?
  evidenceModules EvidenceModule[]
}

model StructureFeature {
  id                   String          @id @default(cuid())
  snapshotId           String          @unique
  h1Count              Int             @default(1)
  headingDepth         Int             @default(3)
  paragraphCount       Int             @default(0)
  listCount            Int             @default(0)
  tableCount           Int             @default(0)
  wordCount            Int             @default(0)
  schemaTypes          String?
  headingScore         Int             @default(70)
  extractabilityScore  Int             @default(70)
  evidenceDensityScore Int             @default(70)
  freshnessScore       Int             @default(70)
  schemaScore          Int             @default(60)
  snapshot             ContentSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
}

model EvidenceModule {
  id           String          @id @default(cuid())
  snapshotId   String
  moduleType   String
  title        String
  body         String
  locationPath String
  factLevel    String          @default("medium")
  reviewStatus String          @default("machine")
  confidence   Float           @default(0.75)
  snapshot     ContentSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
}

model AssetClusterMapping {
  id          String       @id @default(cuid())
  assetId     String
  clusterId   String
  mappingType String       @default("target")
  confidence  Float        @default(0.8)
  asset       ContentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model RunMetric {
  id                     String    @id @default(cuid())
  runId                  String    @unique
  sourceSelection        Boolean   @default(false)
  citationCoverage       Boolean   @default(false)
  brandMentioned         Boolean   @default(false)
  validAnswerInfluence   Boolean   @default(false)
  absorptionScore        Float     @default(0)
  citationFaithfulness   Float     @default(0)
  errorDescriptionScore  Float     @default(0)
  competitorSubstitution Boolean   @default(false)
  stabilitySignal        Float     @default(1)
  evidenceJson           String?
  run                    AnswerRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model QueryMetric {
  id                         String   @id @default(cuid())
  queryId                    String
  windowStart                DateTime
  windowEnd                  DateTime
  vair                       Float    @default(0)
  sourceSelectionRate        Float    @default(0)
  citationCoverageRate       Float    @default(0)
  absorptionScore            Float    @default(0)
  errorDescriptionRate       Float    @default(0)
  competitorSubstitutionRate Float    @default(0)
  stabilityScore             Float    @default(0)
  metricVersion              String   @default("v1")
  query                      Query    @relation(fields: [queryId], references: [id], onDelete: Cascade)
}

model ClusterMetric {
  id                         String       @id @default(cuid())
  clusterId                  String
  windowStart                DateTime
  windowEnd                  DateTime
  vair                       Float        @default(0)
  sourceSelectionRate        Float        @default(0)
  citationCoverageRate       Float        @default(0)
  absorptionScore            Float        @default(0)
  errorDescriptionRate       Float        @default(0)
  competitorSubstitutionRate Float        @default(0)
  stabilityScore             Float        @default(0)
  worstQueryScore            Float        @default(0)
  negativeImpactRate         Float        @default(0)
  metricVersion              String       @default("v1")
  cluster                    QueryCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
}

model ProjectMetric {
  id                         String   @id @default(cuid())
  projectId                  String
  windowStart                DateTime
  windowEnd                  DateTime
  vair                       Float    @default(0)
  sourceSelectionRate        Float    @default(0)
  citationCoverageRate       Float    @default(0)
  absorptionScore            Float    @default(0)
  errorDescriptionRate       Float    @default(0)
  competitorSubstitutionRate Float    @default(0)
  stabilityScore             Float    @default(0)
  metricVersion              String   @default("v1")
}

model Finding {
  id             String            @id @default(cuid())
  projectId      String
  clusterId      String?
  stage          String
  title          String
  description    String
  rootCause      String
  severity       String            @default("P2")
  status         String            @default("open")
  ownerTeam      String            @default("Product")
  recommendation String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cluster        QueryCluster?     @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  evidence       FindingEvidence[]
  tasks          Task[]
  alerts         Alert[]
}

model FindingEvidence {
  id        String     @id @default(cuid())
  findingId String
  runId     String?
  evidence  String
  finding   Finding    @relation(fields: [findingId], references: [id], onDelete: Cascade)
  run       AnswerRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
}

model Task {
  id                   String         @id @default(cuid())
  projectId            String
  findingId            String?
  targetAssetId        String?
  targetClusterId      String?
  taskType             String
  title                String
  description          String
  ownerTeam            String
  assigneeId           String?
  status               String         @default("todo")
  expectedMetricImpact String?
  riskLevel            String         @default("medium")
  dueDate              DateTime?
  externalTicketUrl    String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  project              Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  finding              Finding?       @relation(fields: [findingId], references: [id], onDelete: SetNull)
  targetAsset          ContentAsset?  @relation(fields: [targetAssetId], references: [id], onDelete: SetNull)
  targetCluster        QueryCluster?  @relation(fields: [targetClusterId], references: [id], onDelete: SetNull)
  assignee             User?          @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  timeline             TaskTimeline[]
}

model TaskTimeline {
  id        String   @id @default(cuid())
  taskId    String
  status    String
  note      String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Experiment {
  id                      String         @id @default(cuid())
  projectId               String
  clusterId               String?
  name                    String
  hypothesis              String
  targetMetric            String
  guardrailMetrics        String
  status                  String         @default("draft")
  baselineWindow          String
  posttestWindow          String
  minimumRepeats          Int            @default(3)
  successThreshold        Float          @default(0.1)
  negativeImpactThreshold Float          @default(0.05)
  resultSummary           String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  project                 Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cluster                 QueryCluster?  @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  strategyCards           StrategyCard[]
}

model StrategyCard {
  id                String      @id @default(cuid())
  projectId         String
  experimentId      String?
  strategyName      String
  applicableIntents String
  assetTypes        String
  changePattern     String
  observedUplift    Float       @default(0)
  riskNotes         String
  doNotUseWhen      String
  status            String      @default("published")
  createdAt         DateTime    @default(now())
  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  experiment        Experiment? @relation(fields: [experimentId], references: [id], onDelete: SetNull)
}

model AuthoritySource {
  id                 String  @id @default(cuid())
  projectId          String
  domain             String
  sourceType         String
  topicCoverage      String
  citationCount      Int     @default(0)
  competitorMentions Int     @default(0)
  brandCovered       Boolean @default(false)
  authorityScore     Int     @default(50)
  project            Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AuthorityOpportunity {
  id              String  @id @default(cuid())
  projectId       String
  sourceDomain    String
  clusterName     String
  opportunityType String
  priority        Int     @default(3)
  score           Int     @default(50)
  reason          String
  status          String  @default("open")
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AlertRule {
  id        String  @id @default(cuid())
  projectId String
  name      String
  ruleType  String
  threshold Float
  enabled   Boolean @default(true)
  severity  String  @default("P2")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  alerts    Alert[]
}

model Alert {
  id         String     @id @default(cuid())
  projectId  String
  ruleId     String?
  findingId  String?
  title      String
  message    String
  severity   String     @default("P2")
  status     String     @default("triggered")
  createdAt  DateTime   @default(now())
  resolvedAt DateTime?
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rule       AlertRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  finding    Finding?   @relation(fields: [findingId], references: [id], onDelete: SetNull)
}

model Report {
  id        String   @id @default(cuid())
  projectId String
  type      String
  title     String
  markdown  String
  status    String   @default("generated")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model LlmConfig {
  id                 String   @id @default(cuid())
  projectId          String   @unique
  baseUrl            String
  modelName          String
  scenarioModelNames String?
  apiKey             String
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model IntegrationConfig {
  id          String            @id @default(cuid())
  projectId   String
  type        String
  name        String
  endpointUrl String
  enabled     Boolean           @default(false)
  secretHint  String?
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]
}

model WebhookDelivery {
  id             String            @id @default(cuid())
  integrationId  String
  eventType      String
  payload        String
  status         String            @default("queued")
  responseStatus Int?
  failureReason  String?
  retryCount     Int               @default(0)
  createdAt      DateTime          @default(now())
  integration    IntegrationConfig @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  projectId String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  detail    String
  createdAt DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
